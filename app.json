{
  "expo": {
    "name": "wakeupbrah",
    "slug": "wakeupbrah",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/adaptive-icon.png",
    "scheme": "wakeupbrah",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDEDD2"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.elgabrielcisneros.wakeupbrah"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.elgabrielcisneros.wakeupbrah",
      "permissions": [
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Manrope-Regular.ttf",
            "./assets/fonts/Inter_18pt-Regular.ttf"
          ],
          "android": {
            "fonts": [
              {
                "fontFamily": "Inter",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Inter_18pt-Bold.ttf",
                    "weight": "700"
                  },
                  {
                    "path": "./assets/fonts/Inter_18pt-Italic.ttf",
                    "weight": "400",
                    "style": "italic"
                  },
                  {
                    "path": "./assets/fonts/Inter_18pt-Light.ttf",
                    "weight": "200"
                  },
                  {
                    "path": "./assets/fonts/Inter_18pt-Medium.ttf",
                    "weight": "500"
                  },
                  {
                    "path": "./assets/fonts/Inter_18pt-SemiBold.ttf",
                    "weight": "600"
                  }
                ]
              },
              {
                "fontFamily": "Manrope",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/Manrope-Bold.ttf",
                    "weight": "700"
                  },
                  {
                    "path": "./assets/fonts/Manrope-SemiBold.ttf",
                    "weight": "600"
                  },
                  {
                    "path": "./assets/fonts/Manrope-Medium.ttf",
                    "weight": "500"
                  },
                  {
                    "path": "./assets/fonts/Manrope-Light.ttf",
                    "weight": "300"
                  },
                  {
                    "path": "./assets/fonts/Manrope-ExtraLight.ttf",
                    "weight": "200"
                  }
                ]
              }
            ]
          }
        }
      ],
      [
        "expo-sqlite",
        {
          "enableFTS": true,
          "useSQLCipher": true,
          "android": {
            "enableFTS": false,
            "useSQLCipher": false
          },
          "ios": {
            "customBuildFlags": [
              "-DSQLITE_ENABLE_DBSTAT_VTAB=1 -DSQLITE_ENABLE_SNAPSHOT=1"
            ]
          }
        }
      ],
      [
        "expo-file-system",
        {
          "supportsOpeningDocumentsInPlace": true,
          "enableFileSharing": true
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "extraMavenRepos": [
              "../../node_modules/@notifee/react-native/android/libs"
            ]
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FDEDD2",
          "image": "./assets/images/splash-icon.png",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#FDEDD2"
          },
          "imageWidth": 200
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "62e60af8-0161-4662-bafa-2290663b127a"
      }
    },
    "owner": "brah-tek"
  }
}
